# === AI Provider Configuration ===
# Supported providers: gemini | openai | claude
AI_PROVIDER=gemini

# API key for your chosen provider
# - Gemini:  https://aistudio.google.com/apikey
# - OpenAI:  https://platform.openai.com/api-keys
# - Claude:  https://console.anthropic.com/settings/keys
AI_API_KEY="your-api-key-here"

# (Optional) Override the default model for your provider
# Defaults: gemini-2.5-flash | gpt-4o | claude-sonnet-4-20250514
# AI_MODEL=

# === Lichess Integration ===
# Personal API token for exporting games to Lichess studies
# Generate one at: https://lichess.org/account/oauth/token
# Required scopes: study:read, study:write
# LICHESS_TOKEN=
